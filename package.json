{
  "name": "sourceaxis-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-neutral TypeScript SDK for interacting with Git repositories.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run validate:architecture",
    "changeset": "changeset",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:dry-run": "node scripts/release/pack-dry-run.mjs",
    "release:check": "pnpm lint && pnpm build && pnpm typecheck && pnpm test && pnpm run validate:architecture && pnpm run pack:dry-run",
    "test": "vitest run",
    "typecheck": "turbo run typecheck && tsc --noEmit",
    "validate:architecture": "vitest run scripts/validation/repository-structure.test.mjs",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "9.39.4",
    "@octokit/rest": "^22.0.1",
    "@types/node": "22.16.0",
    "eslint": "9.39.4",
    "prettier": "3.9.4",
    "turbo": "2.10.2",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
