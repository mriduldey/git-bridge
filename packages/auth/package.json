{
  "name": "@repoferry/auth",
  "version": "0.1.0",
  "description": "Provider-neutral authentication primitives for RepoFerry.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./auth-config": {
      "types": "./dist/esm/auth-config.d.ts",
      "import": "./dist/esm/auth-config.js",
      "require": "./dist/cjs/auth-config.js",
      "default": "./dist/esm/auth-config.js"
    },
    "./auth-context": {
      "types": "./dist/esm/auth-context.d.ts",
      "import": "./dist/esm/auth-context.js",
      "require": "./dist/cjs/auth-context.js",
      "default": "./dist/esm/auth-context.js"
    },
    "./auth-kind": {
      "types": "./dist/esm/auth-kind.d.ts",
      "import": "./dist/esm/auth-kind.js",
      "require": "./dist/cjs/auth-kind.js",
      "default": "./dist/esm/auth-kind.js"
    },
    "./credentials": {
      "types": "./dist/esm/credentials.d.ts",
      "import": "./dist/esm/credentials.js",
      "require": "./dist/cjs/credentials.js",
      "default": "./dist/esm/credentials.js"
    },
    "./factory": {
      "types": "./dist/esm/factory.d.ts",
      "import": "./dist/esm/factory.js",
      "require": "./dist/cjs/factory.js",
      "default": "./dist/esm/factory.js"
    },
    "./guards": {
      "types": "./dist/esm/guards.d.ts",
      "import": "./dist/esm/guards.js",
      "require": "./dist/cjs/guards.js",
      "default": "./dist/esm/guards.js"
    },
    "./redaction": {
      "types": "./dist/esm/redaction.d.ts",
      "import": "./dist/esm/redaction.js",
      "require": "./dist/cjs/redaction.js",
      "default": "./dist/esm/redaction.js"
    }
  },
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && node ../../scripts/build/build-cjs.mjs .",
    "test": "vitest run --config vitest.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repoferry/contracts": "workspace:*",
    "@repoferry/errors": "workspace:*",
    "@repoferry/shared": "workspace:*"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mriduldey/repo-ferry.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/mriduldey/repo-ferry/issues"
  },
  "homepage": "https://github.com/mriduldey/repo-ferry#readme",
  "keywords": [
    "git",
    "github",
    "sdk",
    "typescript",
    "provider-neutral"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
