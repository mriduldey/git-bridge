{
  "name": "@gitbridge/contracts",
  "version": "0.0.0",
  "description": "Provider-neutral public contracts and immutable domain models for GitBridge.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./authentication": {
      "types": "./dist/authentication/index.d.ts",
      "default": "./dist/authentication/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "default": "./dist/capabilities/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics/index.d.ts",
      "default": "./dist/diagnostics/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "default": "./dist/domain/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata/index.d.ts",
      "default": "./dist/metadata/index.js"
    },
    "./pagination": {
      "types": "./dist/pagination/index.d.ts",
      "default": "./dist/pagination/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "default": "./dist/provider/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "default": "./dist/transport/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
