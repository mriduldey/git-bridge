{
  "name": "@gitbridge/shared",
  "version": "0.0.0",
  "description": "Provider-neutral shared utilities for GitBridge packages.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assertions": {
      "types": "./dist/assertions/index.d.ts",
      "default": "./dist/assertions/index.js"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "default": "./dist/async/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "default": "./dist/guards/index.js"
    },
    "./objects": {
      "types": "./dist/objects/index.d.ts",
      "default": "./dist/objects/index.js"
    },
    "./paths": {
      "types": "./dist/paths/index.d.ts",
      "default": "./dist/paths/index.js"
    },
    "./strings": {
      "types": "./dist/strings/index.d.ts",
      "default": "./dist/strings/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
