{
  "name": "@repoferry/observability",
  "version": "0.1.0",
  "description": "Provider-neutral diagnostics, logging, metrics, and tracing primitives for RepoFerry.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && node ../../scripts/build/build-cjs.mjs .",
    "test": "vitest run --config vitest.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repoferry/contracts": "workspace:*",
    "@repoferry/errors": "workspace:*",
    "@repoferry/shared": "workspace:*"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mriduldey/repo-ferry.git",
    "directory": "packages/observability"
  },
  "bugs": {
    "url": "https://github.com/mriduldey/repo-ferry/issues"
  },
  "homepage": "https://github.com/mriduldey/repo-ferry#readme",
  "keywords": [
    "git",
    "github",
    "sdk",
    "typescript",
    "provider-neutral"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
